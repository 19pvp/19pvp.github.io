 }
+
+bool ALE::OnBGQueueDistribution(BattlegroundQueue* queue, BattleGround* bg, BattlegroundBracketId bracketId, std::map<ObjectGuid, uint32>& distribution)
+{
+    if (!ALEConfig::GetInstance().IsALEEnabled())
+        return false;
+
+    std::lock_guard<std::recursive_mutex> __guard(ALE::GetLock());
+
+    if (!L) return false;
+
+    lua_getglobal(L, "OnBattlegroundQueueDistribution");
+    if (lua_isfunction(L, -1))
+    {
+        Push(bg);
+        Push((uint32)bracketId);
+        
+        if (lua_pcall(L, 2, 1, 0) == 0)
+        {
+            bool handled = false;
+            if (lua_istable(L, -1))
+            {
+                handled = true;
+                lua_pushnil(L);
+                while (lua_next(L, -2) != 0)
+                {
+                    if (lua_isstring(L, -2) && lua_isnumber(L, -1))
+                    {
+                        std::string guidStr = lua_tostring(L, -2);
+                        uint32 teamId = lua_tonumber(L, -1);
+                        distribution[ObjectGuid(uint64(std::stoull(guidStr, nullptr, 0)))] = teamId;
+                    }
+                    else if (lua_isnumber(L, -2) && lua_isnumber(L, -1))
+                    {
+                        uint64 guidRaw = lua_tonumber(L, -2);
+                        uint32 teamId = lua_tonumber(L, -1);
+                        distribution[ObjectGuid(guidRaw)] = teamId;
+                    }
+                    lua_pop(L, 1);
+                }
+            }
+            lua_pop(L, 1);
+            return handled;
+        }
+        else
+        {
+            // pop error message
+            std::string err = lua_tostring(L, -1);
+            lua_pop(L, 1);
+            LOG_ERROR("eluna", "OnBattlegroundQueueDistribution error: {}", err);
+        }
+    }
+    else
+    {
+        lua_pop(L, 1);
+    }
+    return false;
+}
