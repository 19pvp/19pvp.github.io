+     * @return bool success
+     */
+    int AddToBattleground(lua_State* L, Player* player)
+    {
+        Battleground* bg = ALE::CHECKOBJ<Battleground>(L, 2);
+        uint32 teamId = ALE::CHECKVAL<uint32>(L, 3);
+
+        if (!player || !bg || teamId >= PVP_TEAMS_COUNT)
+        {
+            ALE::Push(L, false);
+            return 1;
+        }
+
+        // Resurrect if dead
+        if (!player->IsAlive())
+        {
+            player->ResurrectPlayer(1.0f);
+            player->SpawnCorpseBones();
+        }
+
+        // Leave existing queues
+        for (uint8 i = 0; i < PLAYER_MAX_BATTLEGROUND_QUEUES; ++i)
+        {
+            auto playerBgQueueTypeId = player->GetBattlegroundQueueTypeId(i);
+            if (playerBgQueueTypeId != BATTLEGROUND_QUEUE_NONE)
+            {
+                player->RemoveBattlegroundQueueId(playerBgQueueTypeId);
+                sBattlegroundMgr->GetBattlegroundQueue(playerBgQueueTypeId).RemovePlayer(player->GetGUID(), true);
+            }
+        }
+
+        // Leave existing battleground
+        if (Battleground* currentBg = player->GetBattleground())
+            currentBg->RemovePlayerAtLeave(player);
+
+        // Set entry point if not in battleground
+        if (!player->InBattleground())
+            player->SetEntryPoint();
+
+        BattlegroundQueueTypeId bgQueueTypeId = BattlegroundMgr::BGQueueTypeId(bg->GetBgTypeID(), bg->GetArenaType());
+        player->AddBattlegroundQueueId(bgQueueTypeId);
+        uint32 queueSlot = player->GetBattlegroundQueueIndex(bgQueueTypeId);
+        player->SetInviteForBattlegroundQueueType(bgQueueTypeId, bg->GetInstanceID());
+        player->SetBattlegroundId(bg->GetInstanceID(), bg->GetBgTypeID(), queueSlot, true, false, (TeamId)teamId);
+
+        // Send status packet to client
+        WorldPacket data;
+        sBattlegroundMgr->BuildBattlegroundStatusPacket(&data, bg, queueSlot, STATUS_IN_PROGRESS, 0, bg->GetStartTime(), bg->GetArenaType(), (TeamId)teamId);
+        player->SendDirectMessage(&data);
+
+        // Teleport to the battleground map start position
+        sBattlegroundMgr->SendToBattleground(player, bg->GetInstanceID(), bg->GetBgTypeID());
+
+        ALE::Push(L, true);
+        return 1;
+    }
+
+    /**
+     * Removes the player/bot from the queue of the specified bgTypeId.
+     *
+     * @param uint32 bgTypeId
+     * @return bool success
+     */
+    int RemoveFromBattlegroundQueue(lua_State* L, Player* player)
+    {
+        if (!player)
+        {
+            ALE::Push(L, false);
+            return 1;
+        }
+
+        uint32 bgTypeIdVal = ALE::CHECKVAL<uint32>(L, 2);
+        BattlegroundTypeId bgTypeId = BattlegroundTypeId(bgTypeIdVal);
+        BattlegroundQueueTypeId bgQueueTypeId = BattlegroundMgr::BGQueueTypeId(bgTypeId, 0);
+        BattlegroundQueue& bgQueue = sBattlegroundMgr->GetBattlegroundQueue(bgQueueTypeId);
+
+        if (player->InBattlegroundQueueForBattlegroundQueueType(bgQueueTypeId))
+        {
+            uint32 queueSlot = player->GetBattlegroundQueueIndex(bgQueueTypeId);
+            bgQueue.RemovePlayer(player->GetGUID(), true);
+            player->RemoveBattlegroundQueueId(bgQueueTypeId);
+
+            // Send status packet update to client
+            WorldPacket data;
+            sBattlegroundMgr->BuildBattlegroundStatusPacket(&data, nullptr, queueSlot, STATUS_NONE, 0, 0, 0, TEAM_NEUTRAL);
+            player->SendDirectMessage(&data);
+
+            ALE::Push(L, true);
+            return 1;
+        }
+
+        ALE::Push(L, false);
+        return 1;
+    }
+
+    /**
+     * Gets the team ID the player is currently queued for in the specified battleground.
+     *
+     * @param uint32 bgTypeId
+     * @return uint32 teamId
+     */
+    int GetBattlegroundQueueTeam(lua_State* L, Player* player)
+    {
+        if (!player)
+        {
+            ALE::Push(L, (uint32)TEAM_NEUTRAL);
+            return 1;
+        }
+
+        uint32 bgTypeIdVal = ALE::CHECKVAL<uint32>(L, 2);
+        BattlegroundTypeId bgTypeId = BattlegroundTypeId(bgTypeIdVal);
+        BattlegroundQueueTypeId bgQueueTypeId = BattlegroundMgr::BGQueueTypeId(bgTypeId, 0);
+        BattlegroundQueue& bgQueue = sBattlegroundMgr->GetBattlegroundQueue(bgQueueTypeId);
+
+        GroupQueueInfo ginfo;
+        if (bgQueue.GetPlayerGroupInfoData(player->GetGUID(), &ginfo))
+        {
+            ALE::Push(L, (uint32)ginfo.teamId);
+        }
+        else
+        {
+            ALE::Push(L, (uint32)player->GetTeamId());
+        }
+        return 1;
+    }
 };
 #endif
 
