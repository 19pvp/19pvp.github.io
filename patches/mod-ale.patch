+void ALE::OnPlayerJoinBG(Player* pPlayer)
+{
+    START_HOOK(PLAYER_EVENT_ON_PLAYER_JOIN_BG);
+    Push(pPlayer);
+    CallAllFunctions(PlayerEventBindings, key);
+}
+
+void ALE::OnEnterBG(Player* pPlayer, Battleground* bg)
+{
+    START_HOOK(PLAYER_EVENT_ON_ENTER_BG);
+    Push(pPlayer);
+    Push(bg ? bg->GetMapId() : 0);
+    Push(bg ? bg->GetInstanceID() : 0);
+    CallAllFunctions(PlayerEventBindings, key);
+}
+
+void ALE::OnLeaveBG(Player* pPlayer, Battleground* bg)
+{
+    START_HOOK(PLAYER_EVENT_ON_LEAVE_BG);
+    Push(pPlayer);
+    Push(bg ? bg->GetMapId() : 0);
+    Push(bg ? bg->GetInstanceID() : 0);
+    CallAllFunctions(PlayerEventBindings, key);
+}
