+GroupQueueInfo* BattlegroundQueue::DetachPlayerFromGroup(ObjectGuid guid, TeamId teamId)
+{
+    auto playerItr = m_QueuedPlayers.find(guid);
+    if (playerItr == m_QueuedPlayers.end() || !playerItr->second)
+        return nullptr;
+
+    GroupQueueInfo* ginfo = playerItr->second;
+    if (ginfo->Players.size() == 1)
+    {
+        ginfo->teamId = teamId;
+        return ginfo;
+    }
+
+    auto* playerGinfo = new GroupQueueInfo(*ginfo);
+    playerGinfo->Players.clear();
+    playerGinfo->Players.emplace(guid);
+    playerGinfo->teamId = teamId;
+    playerGinfo->IsInvitedToBGInstanceGUID = 0;
+    playerGinfo->RemoveInviteTime = 0;
+
+    ginfo->Players.erase(guid);
+    playerItr->second = playerGinfo;
+    m_QueuedGroups[playerGinfo->BracketId][playerGinfo->GroupType].push_back(playerGinfo);
+    return playerGinfo;
+}
