+bool RandomPlayerbotMgr::IsFixedRosterBot(ObjectGuid::LowType bot)
+{
+    if (!_fixedRosterBotsLoaded)
+    {
+        _fixedRosterBotsLoaded = true;
+        _fixedRosterBots.clear();
+        QueryResult result = PlayerbotsDatabase.Query("SELECT guid FROM playerbots_fixed_roster_guid");
+        if (result)
+        {
+            do
+            {
+                Field* fields = result->Fetch();
+                _fixedRosterBots.insert(fields[0].Get<uint32>());
+            } while (result->NextRow());
+        }
+    }
+    return _fixedRosterBots.find(bot) != _fixedRosterBots.end();
+}
+
 bool RandomPlayerbotMgr::IsRandomBot(ObjectGuid::LowType bot)
 {
+    if (IsFixedRosterBot(bot))
+        return true;
+
     ObjectGuid guid = ObjectGuid::Create<HighGuid::Player>(bot);
     if (!sPlayerbotAIConfig.IsInRandomAccountList(sCharacterCache->GetCharacterAccountIdByGuid(guid)))
         return false;
 
+    if (sPlayerbotAIConfig.minRandomBots == 0 && sPlayerbotAIConfig.maxRandomBots == 0)
+        return true;
+
     if (std::find(currentBots.begin(), currentBots.end(), bot) != currentBots.end())
         return true;
 
