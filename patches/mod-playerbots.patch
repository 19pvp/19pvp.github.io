+void PlayerbotAI::SayBattlegroundCommand(std::string const& text)
+{
+    Battleground* bg = bot->GetBattleground();
+    if (!bg)
+        return;
+
+    WorldPacket data;
+    ChatHandler::BuildChatPacket(data, CHAT_MSG_BATTLEGROUND, text.c_str(), LANG_UNIVERSAL, CHAT_TAG_NONE,
+                                 bot->GetGUID(), bot->GetName());
+    bg->SendPacketToTeam(bot->GetBgTeamId(), &data, bot, true);
+}
+
+void PlayerbotAI::ResetBattlegroundCommand()
+{
+    if (battlegroundCommand == "stay")
+    {
+        ChangeStrategy("-stay", BOT_STATE_NON_COMBAT);
+        ChangeStrategy("-stay", BOT_STATE_COMBAT);
+        aiObjectContext->GetValue<PositionInfo>("pos", "stay")->Reset();
+    }
+    else if (battlegroundCommand == "come")
+    {
+        ChangeStrategy("-follow", BOT_STATE_NON_COMBAT);
+        ChangeStrategy("-follow", BOT_STATE_COMBAT);
+    }
+    else if (battlegroundCommand == "flee")
+    {
+        ChangeStrategy("-runaway", BOT_STATE_NON_COMBAT);
+        ChangeStrategy("-runaway", BOT_STATE_COMBAT);
+    }
+    else if (battlegroundCommand == "focus")
+    {
+        aiObjectContext->GetValue<GuidVector>("prioritized targets")->Reset();
+        aiObjectContext->GetValue<Unit*>("current target")->Set(nullptr);
+        bot->SetTarget();
+    }
+    else if (battlegroundCommand == "support")
+    {
+        std::list<ObjectGuid> const noFocusTargets;
+        aiObjectContext->GetValue<std::list<ObjectGuid>>("focus heal targets")->Set(noFocusTargets);
+        ChangeStrategy("-focus heal targets", BOT_STATE_COMBAT);
+    }
+
+    battlegroundCommand.clear();
+    battlegroundCommandTarget = ObjectGuid::Empty;
+    flagDropTarget = ObjectGuid::Empty;
+}
+
+bool PlayerbotAI::HandleGlobalBattlegroundCommand(uint32 type, std::string const& text, Player* fromPlayer)
+{
+    if (!bot->InBattleground() || (type != CHAT_MSG_BATTLEGROUND && type != CHAT_MSG_BATTLEGROUND_LEADER))
+        return false;
+
+    if (!fromPlayer || fromPlayer->GetBattleground() != bot->GetBattleground() ||
+        fromPlayer->GetBgTeamId() != bot->GetBgTeamId())
+        return true;
+
+    std::string command = text;
+    trim(command);
+    std::string lowerCommand = command;
+    std::transform(lowerCommand.begin(), lowerCommand.end(), lowerCommand.begin(),
+                   [](unsigned char c) { return std::tolower(c); });
+
+    size_t separator = lowerCommand.find_first_of(" \t");
+    if (separator == std::string::npos)
+        return false;
+
+    std::string keyword = lowerCommand.substr(0, separator);
+    std::string targetName = command.substr(separator + 1);
+    trim(targetName);
+    if (targetName.empty() || !normalizePlayerName(targetName))
+        return false;
+
+    bool focus = keyword == "focus" || keyword == "attack" || keyword == "kill";
+    bool support = keyword == "support" || keyword == "help" || keyword == "heal";
+    if (!focus && !support)
+        return false;
+
+    Player* target = ObjectAccessor::FindPlayerByName(targetName.c_str());
+    if (!IsValidPlayer(target) || target->GetBattleground() != bot->GetBattleground() || !target->IsAlive())
+        return true;
+
+    if ((focus && target->GetBgTeamId() == bot->GetBgTeamId()) ||
+        (support && target->GetBgTeamId() != bot->GetBgTeamId()))
+        return true;
+
+    if (ServerFacade::instance().IsDistanceGreaterThan(ServerFacade::instance().GetDistance2d(bot, target), 100.0f))
+        return true;
+
+    ResetBattlegroundCommand();
+    battlegroundCommand = focus ? "focus" : "support";
+
+    if (focus)
+    {
+        aiObjectContext->GetValue<GuidVector>("prioritized targets")->Set({target->GetGUID()});
+        aiObjectContext->GetValue<Unit*>("current target")->Set(target);
+        bot->SetTarget(target->GetGUID());
+        DoSpecificAction("attack", Event("bg command", "", fromPlayer), true);
+    }
+    else
+    {
+        std::list<ObjectGuid> const focusTargets = {target->GetGUID()};
+        aiObjectContext->GetValue<std::list<ObjectGuid>>("focus heal targets")->Set(focusTargets);
+        ChangeStrategy("+focus heal targets", BOT_STATE_COMBAT);
+    }
+
+    return true;
+}
+
+bool PlayerbotAI::HandleBattlegroundCommand(uint32 type, std::string const& text, Player* fromPlayer)
+{
+    if (!bot->InBattleground() || (type != CHAT_MSG_WHISPER && type != CHAT_MSG_BATTLEGROUND &&
+                                   type != CHAT_MSG_BATTLEGROUND_LEADER))
+        return false;
+
+    if (!fromPlayer || fromPlayer->GetBattleground() != bot->GetBattleground() ||
+        fromPlayer->GetBgTeamId() != bot->GetBgTeamId())
+        return true;
+
+    if (type != CHAT_MSG_WHISPER && !strstri(text.c_str(), bot->GetName().c_str()))
+        return true;
+
+    bool pass = strstri(text.c_str(), "pass") || strstri(text.c_str(), "give") || strstri(text.c_str(), "drop");
+    bool stay = strstri(text.c_str(), "stay") || strstri(text.c_str(), "wait") ||
+                strstri(text.c_str(), "hold") || strstri(text.c_str(), "defend") || strstri(text.c_str(), "guard");
+    bool come = strstri(text.c_str(), "follow") || strstri(text.c_str(), "come") ||
+                strstri(text.c_str(), "assist") || strstri(text.c_str(), "regroup");
+    bool flee = strstri(text.c_str(), "flee") || strstri(text.c_str(), "runaway") ||
+                strstri(text.c_str(), "run away") || strstri(text.c_str(), "retreat");
+
+    std::string action;
+    if (pass && bot->GetBattlegroundTypeId() == BATTLEGROUND_WS &&
+        (bot->HasAura(BG_WS_SPELL_WARSONG_FLAG) || bot->HasAura(BG_WS_SPELL_SILVERWING_FLAG)))
+    {
+        ResetBattlegroundCommand();
+        battlegroundCommand = "pass";
+        flagDropTarget = fromPlayer->GetGUID();
+        action = "pass the flag";
+    }
+    else if (stay)
+    {
+        ResetBattlegroundCommand();
+        battlegroundCommand = "stay";
+        if (!DoSpecificAction("stay chat shortcut", Event("bg command", "", fromPlayer), true))
+        {
+            ResetBattlegroundCommand();
+            return true;
+        }
+        action = "stay";
+    }
+    else if (come)
+    {
+        ResetBattlegroundCommand();
+        battlegroundCommand = "come";
+        battlegroundCommandTarget = fromPlayer->GetGUID();
+        if (!DoSpecificAction("follow chat shortcut", Event("bg command", "", fromPlayer), true))
+        {
+            ResetBattlegroundCommand();
+            return true;
+        }
+        ChangeStrategy("+follow", BOT_STATE_COMBAT);
+        action = "come";
+    }
+    else if (flee)
+    {
+        ResetBattlegroundCommand();
+        battlegroundCommand = "flee";
+        if (!DoSpecificAction("runaway chat shortcut", Event("bg command", "", fromPlayer), true))
+        {
+            ResetBattlegroundCommand();
+            return true;
+        }
+        action = "flee";
+    }
+    else
+    {
+        if (type == CHAT_MSG_WHISPER)
+            bot->Whisper("You can ask me to stay, come, flee or pass the flag", LANG_UNIVERSAL, fromPlayer);
+        return true;
+    }
+
+    SayBattlegroundCommand("Ok " + fromPlayer->GetName() + ", I will " + action + " now.");
+    return true;
+}
+
+void PlayerbotAI::HandleFlagDropRequest()
+{
+    if (!flagDropTarget)
+        return;
+
